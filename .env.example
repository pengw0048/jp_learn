# Copy this file to .env and fill in real credentials.
# Values already set in your shell take precedence over this file.

JPCORPUS_BANGUMI_CLIENT_ID=
JPCORPUS_BANGUMI_CLIENT_SECRET=
JIMAKU_API_KEY=
JPCORPUS_USER_AGENT=peng/jpcorpus-v0.1

# Optional: any OpenAI-compatible endpoint works here, including a LiteLLM proxy,
# Ollama/Open WebUI style local servers, or a local Apple Foundation Models wrapper.
JPCORPUS_LLM_BASE_URL=https://api.openai.com/v1
JPCORPUS_LLM_MODEL=
JPCORPUS_LLM_API_KEY=

# Must match the redirect URI configured in the Bangumi app.
# The CLI default is http://127.0.0.1:8080/callback.
# JPCORPUS_BANGUMI_REDIRECT_URI=http://127.0.0.1:8080/callback
