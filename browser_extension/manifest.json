{
  "manifest_version": 3,
  "name": "Japanese Reading Companion",
  "version": "0.1.27",
  "description": "Send selected Japanese web text to the local viewer and annotate pages in place.",
  "permissions": ["activeTab", "contextMenus", "notifications", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Toggle Japanese Reading Companion toolbar"
  }
}
